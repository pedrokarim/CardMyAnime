# Base de données (Docker Compose / PostgreSQL 17)
POSTGRES_DB=cardmyanime
POSTGRES_USER=cardmyanime
POSTGRES_PASSWORD=cardmyanime123
POSTGRES_PORT=5432
DATABASE_URL="postgresql://cardmyanime:cardmyanime123@postgres:5432/cardmyanime?schema=public"
DIRECT_URL="postgresql://cardmyanime:cardmyanime123@postgres:5432/cardmyanime?schema=public"

# Alternative locale hors Docker
# DATABASE_URL="postgresql://cardmyanime:cardmyanime123@localhost:5432/cardmyanime?schema=public"
# DIRECT_URL="postgresql://cardmyanime:cardmyanime123@localhost:5432/cardmyanime?schema=public"
# DATABASE_URL="file:./dev.db"

# PROD (Neon)
# DATABASE_URL="postgresql://username:password@hostname:port/database?sslmode=require&pgbouncer=true"
# DIRECT_URL="postgresql://username:password@hostname:port/database?sslmode=require"

PORT=3000

# Auth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key"

# Discord OAuth
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Utilisateurs autorisés
AUTHORIZED_USERS="your-discord-user-id"

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key_here
RECAPTCHA_SECRET_KEY=your_secret_key_here

# Scheduler interne des jobs admin (/admin/cron)
# En dev, il est desactive par defaut (mettre true pour tester localement).
CRON_SCHEDULER_ENABLED=true
CRON_POLL_INTERVAL_MS=30000
CRON_COMMAND_TIMEOUT_MS=120000
